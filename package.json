{
  "name": "gold-savings-review",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/start-local.mjs",
    "desktop:dev": "npm --prefix desktop-tauri run dev",
    "desktop:build": "npm --prefix desktop-tauri run build",
    "status": "node scripts/status-local.mjs",
    "stop": "node scripts/stop-local.mjs",
    "check": "node --check web/app.js",
    "test": "node --test tests/*.test.mjs",
    "test:python": ".venv/bin/python -m unittest tests/test_paddle_ocr_service.py",
    "ocr:serve": ".venv/bin/python python/paddle_ocr_service.py"
  }
}
